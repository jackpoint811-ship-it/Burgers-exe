{
  "name": "burgers-exe-v2-scaffold",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:public": "APP_TARGET=public vite",
    "dev:internal": "APP_TARGET=internal vite",
    "build": "npm run build:public && npm run build:internal",
    "build:public": "APP_TARGET=public vite build",
    "build:internal": "APP_TARGET=internal vite build",
    "typecheck": "tsc --noEmit",
    "preview:public": "npm run build:public && APP_TARGET=public vite preview",
    "preview:internal": "npm run build:internal && APP_TARGET=internal vite preview"
  },
  "dependencies": {
    "@radix-ui/react-tabs": "^1.1.12",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.462.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.14",
    "@types/react-dom": "^18.3.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "@types/node": "^22.10.2"
  }
}
