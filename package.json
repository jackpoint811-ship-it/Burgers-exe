{
  "name": "burgers-exe-v2-scaffold",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:public": "cross-env APP_TARGET=public vite",
    "dev:internal": "cross-env APP_TARGET=internal vite",
    "build": "npm run build:public && npm run build:internal",
    "build:public": "cross-env APP_TARGET=public vite build",
    "build:internal": "cross-env APP_TARGET=internal vite build",
    "typecheck": "tsc --noEmit",
    "preview:public": "npm run build:public && cross-env APP_TARGET=public vite preview",
    "qa:visual": "playwright test --config=playwright.visual.config.ts",
    "preview:internal": "npm run build:internal && cross-env APP_TARGET=internal vite preview",
    "db:v2:migrate:local": "wrangler d1 execute burgers-exe-menu-v2-preview --local --file=./migrations/0001_v2_menu_schema.sql",
    "db:v2:seed:local": "wrangler d1 execute burgers-exe-menu-v2-preview --local --file=./migrations/0002_v2_menu_seed.sql",
    "db:v2:orders:migrate:local": "wrangler d1 execute burgers-exe-menu-v2-preview --local --file=./migrations/0003_v2_orders_schema.sql",
    "db:v2:preview:migrate": "wrangler d1 execute burgers-exe-menu-v2-preview --remote --file=./migrations/0001_v2_menu_schema.sql",
    "db:v2:preview:seed": "wrangler d1 execute burgers-exe-menu-v2-preview --remote --file=./migrations/0002_v2_menu_seed.sql",
    "db:v2:preview:orders:migrate": "wrangler d1 execute burgers-exe-menu-v2-preview --remote --file=./migrations/0003_v2_orders_schema.sql"
  },
  "dependencies": {
    "@radix-ui/react-tabs": "^1.1.12",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.462.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260523.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.14",
    "@types/react-dom": "^18.3.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wrangler": "^4.19.1"
  }
}
